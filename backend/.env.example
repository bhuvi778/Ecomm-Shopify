# MongoDB connection string (use MongoDB Atlas in production)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/gmtmart?retryWrites=true&w=majority

# JWT secret (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Comma-separated list of allowed frontend origins
CLIENT_ORIGIN=https://your-frontend.vercel.app,http://localhost:5173

# Local dev port
PORT=5000
